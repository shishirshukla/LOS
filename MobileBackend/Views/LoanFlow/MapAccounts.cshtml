@model List<Application>
@inject CustomIDataProtection _protector
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
     List<string> ls = new List<string>();
    ls.Add("PL");
    ls.Add("Car");
    ls.Add("HL");
    ls.Add("PL-Ag");
    ls.Add("Express");
    ls.Add("PL-Express");
    ls.Add("PL-SECL");
    ls.Add("KCC");
    ls.Add("KCC-20");
    ls.Add("MUDRA-Simplified");
    ls.Add("MUDRA-Transport");
}

<div class="container">
     <div class="alert alert-danger" role="alert" style="margin-top:5px;">
             @ViewBag.Message
    </div>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>
                    Application No
                </th>
                <th>
                    Name
                </th>
                <th>
                    Applicant Type
                </th>
                <th>
                    Scheme
                </th>
               
                
                <th>
                    Sanctioned By
                </th>
                <th>
                    TL Account Number
                </th>
                <th>
                    CC Account Number
                </th>
                <th>
                    
                </th>
            </tr>
            
        </thead>
        <tbody>
            @foreach(var x in Model)
            {
                <tr id="rw-@x.Id">
                    <td>  @if (!ls.Contains(x.LoanScheme))
                        { 
                           <a href="/LoanFlow/AddControlDetails?Id=@_protector.Decode(x.Id.ToString())" onclick="showModal();">@x.Id</a>

                        }
                        else
                        {
                            <a href="/LoanFlow/Application?Id=@_protector.Decode(x.Id.ToString())" onclick="showModal();">@x.Id</a>
                        }
                     </td>
                    <td>@x.ApplicantShortName</td>
                    <td>@x.TypeOfApplicant</td>
                    <td>@x.LoanScheme</td>
                   
                    <td>@x.SanctionedLevel</td>
                    <td>
                         <input type="text" class="form-control form-control-sm" id="tl-@x.Id" value="0"/>
                    </td>
                    <td> 
                         <input type="text" class="form-control form-control-sm" id="cc-@x.Id" value="0"/>
                    </td>
                    <td>
                        <button id="bt-@x.Id" class=" btn btn-primary btn-sm" onclick="mapac(@x.Id);">Map</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

@section scripts
{
    <script type="text/javascript">
    function mapac(a)
    {
        if(confirm("Are you sure ?"))
        {
           var tlac = $('#tl-' + a).val();
           var ccac = $('#cc-' + a).val();
           if  (tlac == '0' && ccac == '0')
           {
               alert('Both accounts cannot be Zero');
               return;
           }
           else
           {
                    $('#bt-' + a).text('Working');

                    $.ajax({
                        url: "/LoanFlow/MapAccount",
                        type: "GET",
                        contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                        data: { 'Id': a, 'Tl': tlac , 'CC': ccac  }
                    }).done(function (data) {
                        $('#bt-' + a).text('Map');
                        if(data.status == 'Ok')
                        {
                            alert(data.msg);
                            $('#rw-' + a).hide();
                        }
                        else
                        {
                            alert(data.msg);
                        }
                        
                    });
           }
                


        }
       
    }
 
 
</script>
}