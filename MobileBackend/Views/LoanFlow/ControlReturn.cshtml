@model List<Application>
@inject CustomIDataProtection _protector
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="container">
     <div class="alert alert-danger" role="alert" style="margin-top:5px;" >
             @ViewBag.Message
    </div>
    <table class="table table-bordered table-sm" id="myTable">
        <thead>
            <tr>
                <th>
                    Application No
                </th>
                <th>
                    Name
                </th>
               
                <th>
                    Scheme
                </th>
             
                <th>
                    Sanctioned By
                </th>
                  <th>
                    Branch
                </th>
                  <th>
                    AMH
                </th>
                <th></th>
            </tr>
            
        </thead>
        <tbody>
            @foreach(var x in Model)
            {
                <tr>
                    <td><a href="/LoanFlow/Application?Id=@_protector.Decode(x.Id.ToString())">@x.Id</a></td>
                    <td>@x.ApplicantShortName</td>
                   
                    <td>@x.LoanScheme</td>
                   
                  
                    <td>@x.SanctionedLevel</td>
                    <td>@x.Branch.BranchName (@x.BranchId)</td>
                    <td>@x.Branch.AMHCode </td>
                    <td>
                        @if ((x.ControlStatus == "Pending" || x.ControlStatus == "Control Returned") && x.Status == "Sanctioned" &&  (x.MappedTLAccount != null || x.MappedCCAccount != null))
                        {
                            <button class="btn btn-primary btn-sm"  onclick="sendToControl('@_protector.Decode(x.Id.ToString())');">Send To Control</button>


                        }
                        else
                        {
                            <b>A/C Not Mapped</b>
                        }

                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

@section scripts
{
    <link rel="stylesheet" type="text/css" href="/js/datatables.min.css"/>
    <script type="text/javascript" src="/js/datatables.min.js"></script>
    <script src="~/js/datatable-button.js" asp-append-version="true"></script>
    <script src="~/js/html5btn.js" asp-append-version="true"></script>

    <script type="text/javascript">

          $(document).ready( function () {
                    $('#myTable').DataTable({dom: 'Bfrtip',buttons: ['csv', 'pdf']});
        } );
    function sendToControl(a)
    {
        if(confirm("Are you sure ?"))
        {
           
           window.location = '/LoanFlow/UpdateStatus?Id=' + a + '&action1=SendToControl';
             
            
        }
       
    }
 
 
</script>
}