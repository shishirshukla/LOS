@model List<ApplicationUser>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = null;
}
@if (ViewBag.CheckType == "table")
{
    <table class="table table-primary">
    <thead>
        <tr>
            <th>
                User Name
            </th>
            <th>
                Id
            </th>
            <th>
                Designation
            </th>
            <th>
                
            </th>
            <th>
                
            </th>
             <th>
                
            </th>
            <th>
                
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach(var m in Model)
        {
            <tr>
                <td>@m.EmployeeName</td>
                <td>@m.UserName</td>
                <td>@m.Designation</td>
                <td><button  onclick="resetPassword(@m.UserName);">Reset Password</button></td>
                <td> <select id="@m.UserName">
                     <option>Regional Manager</option>
                     <option>Manager Business</option>
                    <option>AMH Head</option>
                    <option>AMH 2nd Officer</option>
                    <option>Branch Manager</option>
                    <option selected="selected">Officer</option>
                    <option>Office Assistant</option>
                </select> </td>
                <td>
                    <button  onclick="changeDesignation(@m.UserName);">Update Designation</button>
                </td>
            </tr>
        }
    </tbody>
    </table>
}
else
{
     foreach(var m in Model)
        {
             <option value="@m.UserName">@m.EmployeeName (@m.UserName - @m.Designation)</option>
        }
}


