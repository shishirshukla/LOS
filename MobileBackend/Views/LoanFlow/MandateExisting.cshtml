@using MobileBackend.Models

@model List<ExistingAcMandate>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    int sno = 1;
}


<section id="tabs" class="project-tab" style="margin-top: 0px;padding:5px;">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <nav>
                    <div class="nav nav-tabs nav-fill" id="nav-tab" role="tablist">
                        <a class="nav-item nav-link active" id="nav-home-tab" data-toggle="tab" href="#nav-home2" role="tab" aria-controls="nav-home" aria-selected="true">LMS Sanctioned List</a>
                        <a class="nav-item nav-link" id="nav-home-tab" data-toggle="tab" href="#nav-home" role="tab" aria-controls="nav-home" aria-selected="false">Non LMS Mandate List</a>

                    </div>
                </nav>
                <div class="tab-content" id="nav-tabContent">
                    <div class="tab-pane active" id="nav-home2" role="tabpanel" aria-labelledby="nav-home-tab">
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>S.No</th>
                                    <th>Application Name</th>
                                    <th>Debit Account</th>
                                    <th>Customer Name</th>
                                    <th>Start Date</th>
                                    <th>Create Date</th>
                                    <th>Status</th>
                                    <th>Last Run Date</th>
                                    <th>Last Run Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in (List<Mandate>)ViewBag.MandateLMS)
                                {
                                    <tr>
                                        <td>@sno</td>
                                        <td>@c.ApplicationDetail.ApplicantShortName</td>
                                        <td>@c.debtor_account_id</td>
                                        <td>@c.debtor_name</td>
                                        <td>@c.first_collection_date</td>
                                        <td>@c.createDate</td>
                                        <td>@c.mandate_status</td>
                                        <td>@c.last_run_date</td>
                                        <td>@c.last_run_status</td>
                                        <td><a href="#" onclick="javascript:checkMandateL('@c.emandate_id')">Check</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                    <div class="tab-pane" id="nav-home" role="tabpanel" aria-labelledby="nav-home-tab">
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>S.No</th>
                                    <th>Credit Account</th>
                                    <th>Debit Account</th>
                                    <th>Customer Name</th>
                                    <th>Start Date</th>
                                    <th>Create Date</th>
                                    <th>Status</th>
                                    <th>Last Run Date</th>
                                    <th>Last Run Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model)
                                {
                                    <tr>
                                        <td>@sno</td>
                                        <td>@c.LoanAc</td>
                                        <td>@c.debtor_account_id</td>
                                        <td>@c.debtor_name</td>
                                        <td>@c.first_collection_date</td>
                                        <td>@c.createDate</td>
                                        <td>@c.mandate_status</td>
                                        <td>@c.last_run_date</td>
                                        <td>@c.last_run_status</td>
                                        <td><a href="#" onclick="javascript:checkMandate('@c.emandate_id')">Check</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
               
            </div>
        </div>
    </div>
</section>








@section scripts
{
    <script type="text/javascript">
         function checkMandate(a)
       {
            $.ajax({   
                url: "/LoanFlow/CheckMandateStatusExisting",   
                type: "GET",   
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',   
                data: {emandate_id:a}   
            }).done(function (data) {
                    alert(data);
            });   
       }
        function checkMandateL(a) {
            $.ajax({
                url: "/LoanFlow/CheckMandateStatus",
                type: "GET",
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                data: { emandate_id: a }
            }).done(function (data) {
                alert(data);
            });
        }
        </script>
    
    
}

