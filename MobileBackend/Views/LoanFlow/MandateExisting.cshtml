@using MobileBackend.Models

@model List<ExistingAcMandate>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    int sno = 1;
}

<table class="table table-sm table-bordered">
    <thead>
        <tr>
            <th>S.No</th>
            <th>Credit Account</th>
            <th>Debit Account</th>
            <th>Customer Name</th>
            <th>Start Date</th>
            <th>Create Date</th>
            <th>Status</th>
            <th>Last Run Date</th>
            <th>Last Run Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var c in Model)
        {
            <tr>
                 <td>@sno</td>
            <td>@c.LoanAc</td>
            <td>@c.debtor_account_id</td>
            <td>@c.debtor_name</td>
            <td>@c.first_collection_date</td>
            <td>@c.createDate</td>
            <td>@c.mandate_status</td>
            <td>@c.last_run_date</td>
            <td>@c.last_run_status</td>
            </tr>
        }
    </tbody>
</table>

@section scripts
{
    
}

