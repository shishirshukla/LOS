@model Application
@inject CustomIDataProtection _protector

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    int slno = 1;
    bool editable = (bool)ViewBag.Editable; 
    string statement1 = "", statement2 = "", statement3 = "", statement4 = "", statement5 = "", statement6 = "", statement7 = "", statement8 = "", statement9 = "", statement10 = "", statement11 = "", statement12 = "", statement13 = "", statement14 = "", statement15 = "";

    if (Model.LoanScheme == "Sme" || Model.LoanScheme == "TPL" || Model.LoanScheme == "PMEGP" || Model.LoanScheme == "MMYSRY" || Model.LoanScheme == "SME-GSS")
    {
        statement1 = "Unit Type (New/Old)";
        statement2 = "Last Filed ITR Details";
        statement3 = "Loan Type (Fresh/Enhancement/Renewal)";
        statement4 = "Existing Turnover";
        statement5 = "Existing Net Profit";
        statement6 = "Projected Turnover";
        statement7 = "Projected Net Profit";
        statement8 = "Other Source of Income";
        statement9 = "Details of CIBIL";
        statement10 = "Project Cost Details";
        statement11 = "Details of Security";
        statement12 = "Details of Guarantor";
        statement13 = "Repayment Details";
        statement14 = "Details of Other Loans";
        statement15 = "CERSAI / Charge Registration Details";
       


    }
    else  if (Model.LoanScheme == "LAP" || Model.LoanScheme == "Topup" )
    {
        statement1 = "Mode of Repayment (SI/ECS) ";
        statement2 = "Gross Monthly Income";
        statement3 = "Net Monthly Income";
        statement4 = "Existing Deduction % (From NMI)";
        statement5 = "Loan Eligibility";
        statement6 = "Latest ITR Filled Year";
        statement7 = "Details of Other Income";
        statement8 = "Details of CIBIL";
        //statement9 = "Details of CIBIL";
        statement10 = "Project Cost Details";
        statement11 = "Details of Security";
        statement12 = "Details of Guarantor";
        statement13 = "Repayment Details";
        statement14 = "Details of Other Loans";
        statement15 = "CERSAI / Charge Registration Details";
       


    }
    else  if (Model.LoanScheme == "DL" || Model.LoanScheme == "OD-Dep" )
    {
        statement1 = "Type of Security (TDR/STDR/LIC etc) ";
        statement2 = "Value of Security (As on loan sanction date)";
        statement3 = "% of Security";
        //statement4 = "Rate of Interest";
        //statement5 = "Loan Eligibility";
        //statement6 = "Latest ITR Filled Year";
        //statement7 = "Details of Other Income";
        //statement8 = "Details of CIBIL";
        //statement9 = "Details of CIBIL";
        //statement10 = "Project Cost Details";
        statement11 = "Details of Security";
        //statement12 = "Details of Guarantor";
        //statement13 = "Repayment Details";
        statement14 = "Details of Other Loans";
        statement15 = "CERSAI / Charge Registration Details";
       


    }
    else   
    {
        statement1 = "Irrigated Agri Land";
        statement2 = "UnIrrigated Agri Land";
        statement3 = "Details of Milch Cattles";
        statement4 = "Details of Pond/Water Body";
        statement5 = "Eligibility";
        statement6 = "Details of Other Income";
        //statement7 = "Details of Other Income";
        statement8 = "Details of CIBIL";
        //statement9 = "Details of CIBIL";
        statement10 = "Project Cost Details";
        statement11 = "Details of Security";
        statement12 = "Details of Guarantor";
        statement13 = "Repayment Details";
        statement14 = "Details of Other Loans";
        statement15 = "CERSAI / Bhuiyan Charge Registration Details";
       


    }
}
<div class="container">

    <div class="alert alert-danger" role="alert" style="margin-top:5px;">
            Application is at : <b>@Model.Owner</b> | Application Type : <b id="LoanScheme">@Model.LoanScheme</b><br/>
        Application status is : <b>@Model.Status</b> , @if (Model.Status == "Sanctioned")
        {
            <span>Controll Status : @Model.ControlStatus</span>
        }
    </div>

   

    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <tr>
            <td colspan="6">
                <b>Basic Application Details</b>
            </td>
        </tr>
        <tr>
            
            <td><b>Branch</b></td>
            <td>@Model.BranchId</td>
            <td><b>Name</b></td>
            <td>@Model.ApplicantShortName</td>
            <td><b>Applicant Type</b></td>
            <td>@Model.TypeOfApplicant</td>
        </tr>
        <tr>
            
            <td><b>Scheme</b></td>
            <td>@Model.LoanScheme</td>
            <td><b>Purpose</b></td>
            <td>@Model.Purpose</td>
            <td><b>Status</b></td>
            <td>@Model.Status</td>
        </tr>
        <tr>
            
            <td><b>Sponsoring Agency</b></td>
            <td>@Model.SponsoringAgency</td>
            <td><b>Subsidy</b></td>
            <td>@Model.SubsidyAmt</td>
            <td><b>Application Date</b></td>
            <td>@Model.ApplicationDate.ToShortDateString()</td>
        </tr>
    </table>


      <table class="table table-bordered table-sm" style="padding-top:5px;">
