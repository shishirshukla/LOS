    <a href="#" id="kharifBtn" class="btn btn-primary btn-sm">
                        Add Kharif Crop</a>    
                        <a href="#" id="rabiBtn" class="btn btn-primary btn-sm">
                        Add Rabi Crop</a>
                        <a href="#" id="summerBtn" class="btn btn-primary btn-sm">
                        Add Summer Crop</a>
                         
                         <a href="#" id="delBtn" class="btn btn-primary btn-sm" onclick="delAll();">
                       Delete All Crops</a>
                       <a href="#" id="splitBtn" class="btn btn-primary btn-sm" onclick="splitLand();">
                       Split Land</a>
</form>


@section scripts
{
    <script type="text/javascript">
     function delAll()
    {
        var a = $('#cif').val();
        if(confirm("Are you sure ?"))
        {
              $.ajax({
                url: "/LoanFlow/DeleteCrops?a=" + a,
                processData: false,
                contentType: false,
                type: 'GET',
                success: function(data){
                    alert(data);
                }
            });
        }
        
    }


    function updateKCC()
    {
        if(confirm("Are you sure ?"))
        {
            var a = $('#cif').val();
            window.location = '/LoanFlow/UpdateKCCLandAccount?Id=' + a ;
        }
    }

     function splitLand()
    {
        if(confirm("Are you sure ?"))
        {
            var a = $('#cif').val();
            window.location = '/LoanFlow/SplitLandExisting?Id=' + a ;
        }
    }

    function saveRes()
    {
        console.log('sac');
        var id = $('#selAc').val();
        var tt = $('#villFB-0').val();
        if (tt != 0)
        {
            $.ajax({
                url: "/LoanFlow/SaveResidence?ac=" + id + "&vill=" + tt ,
              
                processData: false,
                contentType: false,
                type: 'GET',
                success: function(data){
                   alert('Saved');
                }
            });
        }
        
    }

    $(document).ready(function(){
        $('.distDD').change(function(){
            var id = $(this).attr('data-id');
            var tt = $(this).val();
            console.log(id);
            $.ajax({
                url: "/LoanFlow/GetFBTehsil?dd=" + tt,
                data: {dd:tt},
                processData: false,
                contentType: false,
                type: 'GET',
                success: function(data){
                    $('#tehFB-'+id).html(data);
                }
            });

        });
        
    
     $('.tehFB').change(function(){
            var id = $(this).attr('data-id');
            var tt = $(this).val();
            var tehsil = $('#ddFB-'+ id).val();
            console.log(tehsil);
            $.ajax({
                url: "/LoanFlow/GetFBVillage?dd=" + tehsil + "&teh=" + tt ,
                data: {'dd':tt , 'teh':tehsil},
                processData: false,
                contentType: false,
                type: 'GET',
                success: function(data){
                    $('#villFB-'+id).html(data);
                }
            });

        });
    });
    

    function fetchCIF()
    {
        $('#btnCIF').text('Fetching...');
        var a = $('#cif').val();
         $.ajax({   
                url: "/LoanFlow/GetKCCInfo?Id="+a,   
                type: "GET" 
            }).done(function (data) {
                     $('#selAc').val(a);
                     $('#benName').text(data.beneficiaryName);
                     $('#Applicant_First_Name').val(data.aadhaarNumber);
                     $('#Applicant_Middle_Name').val(data.beneficiaryPassbookName);
                     $('#Applicant_Last_Name').val(data.mobile);
                     $('#Dob').val(data.dob);
                     $('#scat').val(data.socialCategory);
                     $('#fcat').val(data.farmerCategory);
                     $('#ftype').val(data.farmerType);
                     $('#kharifBtn').attr('href','/LoanFlow/AddCropExisting?Id='+a+'&season=Kharif');
                     $('#rabiBtn').attr('href','/LoanFlow/AddCropExisting?Id='+a+'&season=Rabi');
                     $('#summerBtn').attr('href','/LoanFlow/AddCropExisting?Id='+a+'&season=Summer');
                     $('#resvil').text(data.residential_vill);
                     $.ajax({   
                            url: "/LoanFlow/GetExistingCrop?Id="+a,   
                            type: "GET" 
                     }).done(function (d){
                        $('#crp').html(d);
                     });
                     $('#btnCIF').text('Fetch Details');
            }); 
    }
</script>
}
