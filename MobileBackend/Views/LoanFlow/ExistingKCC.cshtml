<b>@ViewBag.Message</b>


<form method="post" action="/LoanFlow/AddApplicant" enctype="multipart/form-data" autocomplete="off">
    <input type="hidden" value="@ViewBag.ApplicationId" name="ApplicationId"/>
     <div class="row justify-content-between text-left border border-dark" style="padding-top: 15px;margin-bottom:10px;">
      <div class="form-group col-sm-6 flex-column d-flex">
            <label>KCC A/C Number</label>
     </div>
    <div class="form-group col-sm-3 flex-column d-flex">
         <input type="text" name="cif" id="cif"/>
    </div>
    <div class="form-group col-sm-3 flex-column d-flex">
         <button type="button" onclick="fetchCIF();" id="btnCIF" class="btn btn-primary">Fetch Details</button>
    </div>
     
     </div>
    <div class="row justify-content-between text-left">
  <div class="form-group col-sm-2 flex-column d-flex">
    <label>Beneficiary Name</label>
    <label id="benName">Beneficiary Name</label>
    
  </div>
  
  <div class="form-group col-sm-3 flex-column d-flex">
    <label >Aadhaar Number</label>
    <input type="text" class="form-control-sm" required name="Applicant_First_Name" id="Applicant_First_Name" placeholder="Adhaar" readonly>
  </div>
  <div class="form-group col-sm-3 flex-column d-flex">
    <label >CIF Name</label>
    <input type="text" class="form-control-sm" name="Applicant_Middle_Name" id="Applicant_Middle_Name" placeholder="CIF Name" readonly>
  </div>
  <div class="form-group col-sm-3 flex-column d-flex">
    <label >Mobile Number</label>
    <input type="text" class="form-control-sm" name="Applicant_Last_Name" id="Applicant_Last_Name" placeholder="Mobile Number" readonly>
  </div>
  </div>
  <div class="row justify-content-between text-left">
  <div class="form-group col-sm-3 flex-column d-flex">
    <label>Dob</label>
    <input type="text" class="form-control-sm" name="Dob" id="Dob" placeholder="Date of Birth" readonly>
    
  </div>
  <div class="form-group col-sm-3 flex-column d-flex">
    <label>Social Category</label>
    <input type="text" class="form-control-sm" readonly name="Dob" id="scat" placeholder="" >
    <label>SC (1) ,  ST(2) , GE (3) , OBC(4)</label>
    
  </div>
  <div class="form-group col-sm-3 flex-column d-flex">
    <label>Farmer Category</label>
    <input type="text" class="form-control-sm" readonly name="Dob" id="fcat" placeholder="" >
    <label>OWNER (1) ,  SHARECROPPER(2) , TENANT (3)  </label>
  </div>
  <div class="form-group col-sm-3 flex-column d-flex">
    <label>Farmer Type</label>
    <input type="text" class="form-control-sm" readonly name="Dob" id="ftype" placeholder="">
    <label>SMALL (1) ,  OTHER(2) , MARGINAL (3) </label>
  </div>
  

  </div>
  <div class="row justify-content-between text-left">
      <div class="form-group col-sm-3 flex-column d-flex">
          <label>Residential Village</label>
   
    <label id="resvil"></label>
          </div>
    
  </div>
  <div class="row justify-content-between text-left">
   <div class="form-group col-sm-3 flex-column d-flex">
    <label>District</label>
    <input type="hidden" id="selAc" value=""/>
