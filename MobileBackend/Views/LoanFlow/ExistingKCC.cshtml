  <div class="form-group col-sm-3 flex-column d-flex">
    <label>Tehsil</label>
    <select class="form-control tehFB" id="tehFB-0" data-id="0">

                       </select>
    </div>
    <div class="form-group col-sm-3 flex-column d-flex">
    <label>Village</label>
    <select class="form-control villFB" id="villFB-0" data-id="0">
