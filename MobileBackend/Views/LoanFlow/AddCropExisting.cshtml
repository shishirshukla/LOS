@inject CustomIDataProtection _protector
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    //Layout = null;
}



<form id="frm1" method="post" action="/LoanFlow/AddCrop" enctype="multipart/form-data">
    <input type="hidden" value="@ViewBag.ApplicationId" id="ApplicationId"/>
  
     <div class="row justify-content-between text-left">
      <div class="form-group col-sm-2 flex-column d-flex">
            <label>Season</label>
     </div>
    <div class="form-group col-sm-2 flex-column d-flex">
            <input type="text" class="form-control" name="season" readonly id="season" value="@ViewBag.Season"/>
    </div>
   
     </div>
      
    
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                
                <th>District</th>
                <th>Khasra No</th>
                <th>Total Area (Hect)</th>
                <th>Irrigated (Hect)</th>
                <th>Unirrigated (Hect)</th>
                <th>Crop</th>
                <th>SOF</th>
            </tr>
        </thead>
        <tbody id="landTbl">
            @foreach (var item in (List<KCCExistingLand>)ViewBag.Lands)
           {
               <tr id="@item.Id">
                   <td id="dist-@item.Id">@item.District</td>
                   <td id="kh-@item.Id">@item.KhasraNo</td>
                   <td id="rk-@item.Id">@item.TotalArea</td>
                   <td > <input id="irri-@item.Id" type="text" class="form-control"  value="@item.IrrigatedArea"/></td>
                   <td ><input id="unirri-@item.Id" type="text" class="form-control"  value="@item.UnIrrigatedArea"/></td>
                   <td >
                       <select id="crop-@item.Id" class="form-control sofDD" data-id="@item.Id" >
                           <option value="-1">No Crop</option>
                             @foreach (var k in (List<KeyValue>)ViewBag.crops)
                              {
                                  <option value="@k.code">@k.value</option>
                              }
                       </select>

                     

                   </td>
                   <td>
                       <a href="/LoanFlow/DeleteExistingLand?Id=@item.Id">Delete Land</a>
                   </td>
                   
               </tr>
           }
        </tbody>
    </table>
  
  
  
  <button type="button" class="btn btn-primary" onclick="saveAllData();">Save</button>
  <a href="/LoanFlow/ExistingKCC">Back to Application</a>
</form>

@section scripts
{
<script type="text/javascript">

