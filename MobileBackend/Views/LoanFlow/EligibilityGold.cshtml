@model Application
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = null;
    int slno = 1;
    double elig1 = 0;
    double elig = 0;
    double projCost = (double)((List<ProjectCost>)ViewBag.ProjectCost).Where(b=> b.EligibleForLoan == "Yes").Sum(a => a.Cost);
    double projCost1 = (double)((List<ProjectCost>)ViewBag.ProjectCost).Where(b=> b.EligibleForLoan == "Yes").Sum(a => a.AppliedAmount);
    var l = (Dictionary<int, List<CIBILLoanInfo>>)ViewBag.LoanInfo;
    List<double> repay = new List<double>();
    List<double> nmiTotal = new List<double>();
    List<double> gmiTotal = new List<double>();
    List<DateTime> repayDates = new List<DateTime>();
    decimal netWeight = 0;
    decimal appliedAmt = Model.LoanApplications.Where(a => a.TypeOfFacility == "TL" || a.TypeOfFacility == "OD").FirstOrDefault().AppliedAmount;
    double valueIbja = 0;
    double valueBank = 0;
    var goldRate22K = (float)ViewBag.IbjaRate / 10;
    var goldRate18K = 18 * goldRate22K / 22;
    var goldRate19K = 19 * goldRate22K / 22;
    var goldRate20K = 20 * goldRate22K / 22;
    var goldRate21K = 21 * goldRate22K / 22;
      var goldRate22K1 = (float)ViewBag.AdvRate / 10;
    var goldRate18K1 = 18 * goldRate22K1 / 22;
    var goldRate19K1 = 19 * goldRate22K1 / 22;
    var goldRate20K1 = 20 * goldRate22K1 / 22;
    var goldRate21K1 = 21 * goldRate22K1 / 22;
    Dictionary<string, Single> s = new Dictionary<string, float>();
    s.Add("18K", goldRate18K);
    s.Add("19K", goldRate18K);
    s.Add("20K", goldRate20K);
    s.Add("21K", goldRate18K);
    s.Add("22K", goldRate22K);
     Dictionary<string, Single> s1 = new Dictionary<string, float>();
    s1.Add("18K", goldRate18K1);
    s1.Add("19K", goldRate19K1);

    s1.Add("20K", goldRate20K1);
    s1.Add("21K", goldRate21K1);
    s1.Add("22K", goldRate22K1);
    //  Dictionary<string, Single> s2 = new Dictionary<string, float>();
    //s2.Add("18K", 18);
    //s2.Add("19K", 19);

    //s2.Add("20K", goldRate20K1);
    //s2.Add("21K", goldRate21K1);
    //s2.Add("22K", goldRate22K1);
}

  

   
        <div class="border border-dark">
            <b>Eligibility for Gold Loan</b>
            <br/>
            <table width="100%" id="assetTable">
                <tr>
                    <td><b>Applicant Name</b></td>
                    @foreach(var a in Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor"))
                    {
                        <td>@a.Applicant_First_Name @a.Applicant_Middle_Name @a.Applicant_Last_Name</td>   
                    }
                </tr>
                <tr>
                    <td><b>Occupation</b></td>
                    @foreach(var a in Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor"))
                    {
                        <td>@a.Occupation</td>   
                    }
                </tr>
                 <tr>
                    <td>Details of Applied Amount</td>
                    <td colspan="@Model.Applicants.Count">
                        <table class="table-bordered table-responsive-sm">
                            <tr>
                                <th>S.No.</th>
                                <th>Description</th>
                                <th>Eligible for Bank Finance</th>
                                <th>Cost</th>
                                <th>Bank Finance</th>
                            </tr>
                            @{
                int pjCount = 1;
            }
            @foreach(var x in (List<ProjectCost>)ViewBag.ProjectCost)
            {
                <tr>
                    <td>@pjCount</td>
                    <td>@x.Description</td>
                    <td>@x.EligibleForLoan  </td>
                    <td>@x.Cost</td>
                    <td>@x.AppliedAmount</td>
                   
                   
                </tr>
                pjCount++;
            }
            <tr>
                <td></td>
                <td>Total</td>
                <td></td>
                <td>@projCost</td>
                <td>@projCost1</td>
            </tr>
            </table>
            </td>
            </tr>
                 <tr>
                    <td><b>Applied Amt.</b></td>
                    <td colspan="@Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor").Count()">
                            @Model.LoanApplications.Where(a=> a.TypeOfFacility == "TL" || a.TypeOfFacility == "OD").FirstOrDefault().AppliedAmount;
                    </td>
                </tr>
                 <tr>
                    <td><b>Gold Ornaments</b></td>
                        <td colspan="@Model.Applicants.Where(a=> a.Driving_Lic != "Deleted"&& a.TypeofApplicant != "Guarantor").Count()">
                          <table class="table table-sm table-bordered">
                              <thead>
                                  <tr>
                                      <th>Ornament</th>
                                      <th>Purity</th>
                                      <th>Qty</th>
                                      <th>Net Weight (Gms)</th>
                                      <th>Gross Weight (Gms)</th>
                                      
                                      <th>Net Weight (On 22K Purity Gms)</th>
                                      
                                  </tr>
                              </thead>
                              <tbody>
                                    @foreach(var x in Model.Securities)
                               {
                                   <tr>
                                       <td>@x.Owner</td>
                                       <td>@x.Description</td>
                                       <td>@x.Boundary</td>
                                       <td>@x.PlotNo</td>
                                       <td>@x.Location</td>
                                        <td>
                                    @{
                                        var p = Math.Round(int.Parse(x.Description.Replace("K", "")) * decimal.Parse(x.PlotNo) / 22,2);
                                        netWeight = netWeight + p;
                                    }
                                            @p
                                        </td>
                                   </tr>
                    
                                }
                                <tr>
                                    <td colspan="3">
                                        Total
                                    </td>
                                    <td>
                                        @Model.Securities.Where(a=> a.Description.Contains("K")).Sum(a=> Decimal.Parse(a.PlotNo))
                                    </td>
                                    <td>
                                        @Model.Securities.Where(a=> a.Description.Contains("K")).Sum(a=> Decimal.Parse(a.Location))
                                    </td>
                                    <td>
                                        @netWeight
                                    </td>
                                </tr>
                              </tbody>
                            


                          </table>
                          

                    </td>
                </tr>
                <tr>
                    <td><b>Value as IBJA Rate</b></td>
                    <td colspan="@Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor").Count()">
                          
                          Rs. @goldRate22K / Gm

                          
                    </td>
                </tr>
                <tr>
                    <td><b>Screenshot</b></td>
                    <td style="height:150px;">
                        <img style="max-height: 400px;" class="img-fluid"  src="data:image/png;base64, @ViewBag.IbjaProof" />

                    </td>
                </tr>
                <tr>
                    <td><b>Value as Bank Circular</b></td>
                    <td colspan="@Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor").Count()">
                          
                          Rs. @goldRate22K1 / Gm 
                          (Circular No - @ViewBag.GoldLoanCircular)
                    </td>
                </tr>
                <tr>
                    <td><b>Valuation Considered</b></td>
                    <td colspan="@Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor").Count()">
                          
                          Rs. @Math.Min(goldRate22K,goldRate22K1) / Gm
                    </td>
                </tr>
                 <tr>
                    <td><b>Eligibility as per Valuation </b></td>
                    <td  colspan="@Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor").Count()">
                            @(Math.Round(0.75 * Math.Min(goldRate22K,goldRate22K1) * (double)netWeight,2))  (Margin 25%)
                    </td>
                </tr>
             
               
                <tr>
                    <td><b>Eligible Amount</b></td>
                    <td id="eliAmt" colspan="@Model.Applicants.Where(b=> b.Driving_Lic != "Deleted" && b.TypeofApplicant != "Guarantor").Count()">
                            @Math.Min((double)appliedAmt,Math.Round(0.75 * Math.Min(goldRate22K,goldRate22K1) * (double)netWeight,2))
                    </td>
                </tr>


            </table>
        </div>
            
