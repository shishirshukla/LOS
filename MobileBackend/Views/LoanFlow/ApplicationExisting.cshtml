}
<div class="container">


   

    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <tr>
            <td colspan="6">
                <b>Basic Account Details</b>
            </td>
           
        </tr>
        <tr>
            
            <td><b>Branch</b></td>
            <td>@Model.BranchId</td>
            <td><b>Name</b></td>
            <td>@Model.AccountName</td>
            <td><b>Account No</b></td>
            <td>@Model.AccountNo</td>
           
        </tr>
        <tr>
            
            <td><b>Scheme</b></td>
            <td>@Model.ProductDesc</td>
            <td><b>Porduct Code</b></td>
            <td>@Model.AccountType @Model.IntCat</td>
            <td><b>IRAC</b></td>
            <td>@Model.IracStatus</td>
            
        </tr>
        <tr>
            
            <td><b>Outstanding</b></td>
            <td>@Model.CurrentOs</td>
            <td><b>Limit</b></td>
            <td>@Model.OdLimit</td>
            <td><b>Open Date</b></td>
            <td>@Model.AcOpenDate</td>
            
        </tr>
       
    </table>

   

    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td colspan="5">Details of Applicant</td>
                <td colspan="2"> @if (editable)
                    {
                        
                    }
                    </td>
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Name
                </th>
                <th>
                    CIF
                </th>
                <th>
                    Date of Birth
                </th>
                <th>
                    Occupation
                </th>
                <th>
                    Credit Score
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody id="applicantTable">
            @foreach(var x in Model.Applicants.Where(a=> a.Driving_Lic != "Deleted"))
            {

                <tr>
                    <td>@slno</td>
                    <td>@x.Applicant_First_Name @x.Applicant_Middle_Name @x.Applicant_Last_Name @x.Relationship @x.Guardian_Name</td>
                    <td>@x.ExistingCIF</td>
                    <td>@x.Date_Of_Birth</td>
                    <td>@x.Occupation</td>
                    <td>
                        @x.CreditScore
                        
                    </td>
                    <td>
                    <form action="/LoanFlow/EditApplicantExisting" method="post">
                        <input type="hidden" name="Id" value="@x.Id"/>
                        <button type="submit">Edit</button>
                    </form>
                       
                        
                    </td>
                </tr>
                slno++;
            }
        </tbody>

    </table>

   
   


    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="9">Cibil Loan Details</th>
            </tr>
            <tr>
                <th>S.No.</th>
                <th>Member Name</th>
                <th>Account Type</th>
                <th>Open Date</th>
                <th>Close Date</th>
                <th>Current Outstanding</th>
                <th>Amount Overdue</th>
                <th>Status</th>
                <th>Status Date</th>
                
            </tr>
        </thead>
        <tbody id="cibilTable">
            @{
                int sn = 1;
            }
            @foreach (var item in (List<CibilAccounts>)ViewBag.Cibil)
           {
               <tr>
                   <td>
                       @sn
                   </td>
                   <td>
                       @item.member_name
                   </td>
                   <td>
                       @item.acc_type
                   </td>
                   <td>
                       @item.date_open
                   </td>
                   <td>
                       @item.date_close
                   </td>
                   <td>
                       @item.current_bal
                   </td>
                   <td>
                       @item.amt_overdue
                   </td>
                   <td>
                       @item.hist1
                   </td>
                   <td>
                       @item.hist1_date
                   </td>
               </tr>
               sn++;
           }
        </tbody>
    </table>

      <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td colspan="3"><b>Attached Documents</b></td>
                <td colspan="2">
                 
                    
                        <a href="#"  class="btn btn-primary btn-sm" data-toggle="modal" data-target="#applicantModal">
 Add 
</a> 
                    

                    

</td>
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Description
                </th>
                <th>
                    UserId
                </th>
                <th>
                    File Download
