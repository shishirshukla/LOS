        </thead>
        <tbody id="inspectionTable">
           
        </tbody>

    </table>


</div>

<div id="toast" class="toast" role="alert" aria-live="assertive" data-delay=1500 aria-atomic="true" style="position: absolute; top:0; right: 40%;">
  <div class="toast-header">
    <img src="..." class="rounded mr-2" alt="...">
    <strong class="mr-auto">Bootstrap</strong>
    <small>11 mins ago</small>
    <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>
  <div class="toast-body">
    Hello, world! This is a toast message.
  </div>
</div>


<input  type="hidden" id="toastMessage" data-msg="@ViewData["DMessage"].ToString()" value="@ViewData["Message"].ToString()"/>

@section scripts
{
    <script type="text/javascript">

        function showMsg()
        {
             iziToast.success({
                    title: 'Success!',
                    message: 'Data saved sucessfully' ,
                    position: 'topRight'
                });
        }

        function showMsg1(a)
        {
             iziToast.success({
                    title: 'Error!',
                    message: a ,
                    position: 'topRight'
                });
        }

        $(document).ready(function(){
            console.log('Ready State');
            if($('#toastMessage').val() == "OK")
            {
                showMsg();
            }
            else if($('#toastMessage').val() == "BAD")
            {
                showMsg1($('#toastMessage').attr('data-msg'));
            }
        });

       

       
</script>
}