    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td colspan="3"><b>Attached Documents</b></td>
                <td colspan="2">
                 
                    
                        <a href="/LoanFlow/AddDocument/@Model.AccountNo"  class="btn btn-primary btn-sm" data-toggle="modal" data-target="#applicantModal">
 Add 
</a> 
                    

                    

</td>
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Description
                </th>
                <th>
                    UserId
                </th>
                <th>
                    File Download
                </th>
               
                <th></th>
            </tr>
        </thead>
        <tbody id="docTable">
            @{
                slno = 1;
            }
          
        </tbody>

    </table>
   
       <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td><b>Inspection Reports</b></td>
               
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Description
                </th>
                <th>
                    UserId
                </th>
                <th>
                    Visit Date
                </th>
                <th>
                    <button type="button" class="btn btn-sm btn-warning" onclick="viewPresanction(@Model.AccountNo,'')" >View Report</button>
                </th>
               
                <th>@if (editable)
                    {
                       @* <button type="button" class="btn btn-sm btn-warning" onclick="addInspection()" >Add Inspection</button>    *@ 
                    }
                    
