                <th></th>
            </tr>
        </thead>
        <tbody id="docTable">
            @{
                slno = 1;
            }
            @foreach(var x in (List<DocumentLoan>)ViewBag.Documents)
            {

                <tr>
                    <td>@slno</td>
                    <td>@x.Details </td>
                    <td>@x.UserId</td>
                    <td><a href="/@x.FilePath" target="_blank">Download</a></td>
                    
                    <td> 
                       
                    </td>
                </tr>
                slno++;
            }
        </tbody>

    </table>


    @if (Model.ProductDesc.Contains("KCC") )
