<input  type="hidden" id="toastMessage" data-msg="@ViewData["DMessage"].ToString()" value="@ViewData["Message"].ToString()"/>

@section scripts
{
    <script type="text/javascript">

        function showMsg()
        {
             iziToast.success({
                    title: 'Success!',
                    message: 'Data saved sucessfully' ,
                    position: 'topRight'
                });
        }
        function showMsg1(a)
        {
             iziToast.success({
                    title: 'Error!',
                    message: a ,
                    position: 'topRight'
                });
        }

        $(document).ready(function(){
            console.log('Ready State');
            if($('#toastMessage').val() == "OK")
            {
                showMsg();
            }
            else if($('#toastMessage').val() == "BAD")
            {
                showMsg1($('#toastMessage').attr('data-msg'));
            }
        });

        $("#applicantModal").on('shown.bs.modal', function () {
           $(this).find('select').select2();
           const input = document.querySelector('input[id="addDoc"]');
            const options = document.querySelectorAll('#options option');

            input.addEventListener('input', function() {
              for (const option of options) {
                if (option.value.toLowerCase().startsWith(this.value.toLowerCase())) {
                  option.style.display = 'block';
                } else {
                  option.style.display = 'none';
                }
              }
            });
        });

       

        
        function searchBC(){
            $('#bcCode').select2();
        }


        $('body, html').on('change','#agencyType', function(e) {
           var id =  $('#agencyType').find(":selected").val();
           var Appid =  $('#agencyType').find(":selected").val();
             $.ajax({   
                url: "/LoanFlow/GetAgencyList",   
                type: "GET",   
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',   
                data: {'br':id , AppId : '@Model.AccountNo'}   
            }).done(function (data) {
                    
                    $('#bcCode').html(data);
                    $('#bcCode').select2();
            });   

        });
       

        $('body, html').on('change','#brListRemark', function(e) {
           var id =  $('#brListRemark').find(":selected").val();
             $.ajax({   
                url: "/LoanFlow/GetUsers",   
                type: "GET",   
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',   
                data: {'br':id , 'CheckType':'oo'}   
            }).done(function (data) {
                    
                    $('#staffList').html(data);
            });   

        });
         $('body, html').on('change','#SecondaryRemark', function(e) {
           var id =  $('#SecondaryRemark').find(":selected").attr('data-id');
           if(id !='0')
           {
               $('.hide1').hide();
               $('.hide1').removeAttr('name');
               $('#' + id).show();
               $('#' + id).attr('name','Statment');
           }
           else{
               $('.hide1').hide();
               $('.hide1').removeAttr('name');
               $('.hide2').show();
               $('.hide2').attr('name','Statment');
           }

        });
        $('body, html').on('change','#TypeOfRemark', function(e) {
           var id =  $('#TypeOfRemark').find(":selected").attr('data-id');
           if(id !='0')
           {
               $('.hide1').hide();
               $('.hide1').removeAttr('name');
               $('.hide1').removeAttr('required');
               $('#' + id).show();
               $('#' + id).attr('name','Statment');

           }
           else{
               $('.hide1').hide();
               $('.hide1').removeAttr('name');
               $('.hide2').show();
               $('.hide2').attr('name','Statment');
                $('.hide2').attr('required','required');
           }

        });


        function pNote(a,b)
       {
            
           //http://10.80.1.123:2000/docGenerate/processNotePer?appID=4
           window.location = '/Home/Document?docType=processNote&AppID=' + a + '&LoanType='+b+'&docId=4';
       }
       function arrLetter(a,b)
       {
           window.location = '/Home/Document?docType=getDoc&AppID=' + a + '&LoanType='+b+'&docId=1';
       }
       function agLetter(a,b)
       {
           window.location = '/Home/Document?docType=getDoc&AppID=' + a + '&LoanType='+b+'&docId=2';
       }
       function gLetter(a,b)
       {
           window.location = '/Home/Document?docType=getDoc&AppID=' + a + '&LoanType='+b+'&docId=3';
       }
       function scoreCard(a,b)
       {
           window.location = '/Home/Document?docType=scoreCard&AppID=' + a + '&LoanType='+b+'&docId=3';
       }
       function adLetter(a,b)
       {
           var count = $("#remarkSection tr").length;
            if(count == 0)
            {
                alert('Remarks not recorded , Cannot proceed !');
                return;
            }
            else
            {
                count = $('#Mode_of_Repayment').length;
                if(count == 0)
                {
                    alert('Repayment Mode not recorded , Cannot proceed  !');
                    return;
                }
                
            }
            window.location = '/Home/Document?docType=loanForm&AppID=' + a + '&LoanType='+b+'&docId=4';
       }
    function sanction(a)
    {
        if(confirm("Are you sure ?"))
        {
            if ($('#LoanScheme').val() == "HL")
            {
                
                var count = $("#HLRemarks tr").length;
                if(count == 0)
                {
                    alert('No Hl Remarks present , Cannot proceed to sanction !');
                    return;
                }
                count = $("#LTV").length;
                if(count == 0)
                {
                    alert('LTV Not defined, Cannot proceed to sanction !');
                    return;
                }
                count = $("#Repayment_During_Moratorium").length;
                if(count == 0)
                {
                    alert('Moratorium Interest Repayment Not defined, Cannot proceed to sanction !');
                    return;
                }
                count = $("#Purpose_of_HL").length;
                if(count == 0)
                {
                    alert('HL Purpose not defined, Cannot proceed to sanction !');
                    return;
                }
                count = $("#Proposed_HL_Address").length;
                if(count == 0)
                {
                    alert('LTV Not defined, Cannot proceed to sanction !');
                    return;
                }
            }
            var count = $("#applicantTable tr").length;
            if(count == 0)
            {
                alert('No Applicant present , Cannot proceed to sanction !');
                return;
            }
            count = $("#cibilTable tr").length;
            if(count == 0)
            {
                alert('CIBIL not verified , Cannot proceed to sanction !');
                return;
            }
            count = $("#loanTable tr").length;
            if(count == 0)
            {
                alert('Loan application not present , Cannot proceed to sanction !');
                return;
            }
            count = $("#inspectionTable tr").length;
            if(count == 0)
            {
                alert('Presanction not recorded , Cannot proceed to sanction !');
                return;
            }
            count = $("#docTable tr").length;
            if(count == 0)
            {
                alert('No documents uploaded, Cannot proceed to sanction !');
                return;
            }
            count = $("#remarkSection tr").length;
            if(count == 0)
            {
                alert('Recomendation not recorded , Cannot proceed to sanction !');
                return;
            }
            else
            {
                if($('#LoanScheme').val() == "HL" || $('#LoanScheme').val() == "Car" || $('#LoanScheme').val() == "PL" || $('#LoanScheme').val() == "PL-Agri" || $('#LoanScheme').val() == "PL-SECL")
                {
                    count = $('#CreditScore').length;
                    if(count == 0)
                    {
                        alert('Score card details not filled , Cannot proceed to sanction !');
                         return;
                    }
                }

                if($('#LoanScheme').val() == "KCC" || $('#LoanScheme').val() == 'KCC-20')
                {
                    if(int.Parse($('#appAmt').val()) > 300000)
                    {
                         count = $('#CreditScore').length;
                        if(count == 0)
                        {
                             alert('Score card details not filled , Cannot proceed to sanction !');
                             return;
                        }
                    }
                }
                
                count = $('#Branch_Recomendation').length;
                if(count == 0)
                {
                    alert('Branch Recomendation not filled , Cannot proceed to sanction !');
                    return;
                }
                if($('#LoanScheme').text() == 'HL')
                {
                     count = $('#LTV').length;
                     if(count == 0)
                     {
                        alert('LTV not filled , Cannot proceed to sanction !');
                        return;
                     }
                }
            }
           
            window.location = '/LoanFlow/Sanction?Id=' + a;
             
            
        }
       
    }
    function reject(a)
    {
        if(confirm("Are you sure ?"))
        {
            var count = $("#remarkSection tr").length;
            if(count == 0)
            {
                alert('Remarks not recorded , Cannot proceed !');
                return;
            }
            else
            {
                count = $('#RejectRemarks').length;
                if(count == 0)
                {
                    alert('Return Remarks not recorded , Cannot proceed  !');
                    return;
                }
                
            }
            window.location = '/LoanFlow/UpdateStatus?Id=' + a + '&action1=Reject';
        }
        
    }
