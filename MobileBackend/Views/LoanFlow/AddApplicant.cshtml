@section scripts
{
    <script type="text/javascript">

    $('#OccupationDD').change(function() {
        var c = $('#OccupationDD').find(":selected").val();
        if (c == 'Not Working')
        {
            $('#WorkingSince').removeAttr('required');
        }
        else
        {
            $('#WorkingSince').removeAttr('required');
            $('#WorkingSince').addAttr('required');

        }
        
    });

    function fetchCIF()
    {
        $('#btnCIF').text('Fetching...');
        var a = $('#cif').val();
         $.ajax({   
                url: "/LoanFlow/GetCIFDetails?Id="+a,   
                type: "GET" 
            }).done(function (data) {
                     var x = data.cname.split(' ');
                     if(x.length > 0 )
                     {
                         $('#Applicant_First_Name').val(x[0]);
                         if(x.length == 2 )
                         {
                             $('#Applicant_Last_Name').val(x[1]);
                         }
                         else if(x.length > 2 )
                         {
                             $('#Applicant_Middle_Name').val(x[1]);
                             $('#Applicant_Last_Name').val(x[2]);
                         }
                     }
                     else
                     {
                         $('#Applicant_First_Name').val(data.cname);
                     }
                     $('#Address_Line1').val(data.add1);
                     $('#Address_Line2').val(data.add2);
                     $('#City_Village').val(data.add3);
                     $('#PINCode').val(data.pincode);
                     $('#MobileNumber').val(data.phone);
                     $('#Guardian_Name').val(data.father_name);
                     $('#Adhaar_No').val(data.aadhaar);
                     $('#PAN_No').val(data.pan);
                     $('#Date_Of_Birth').val(data.dob);
                      
                       
                     $('#btnCIF').text('Fetch Details');
            }); 
    }
</script>
