@model Application
@inject CustomIDataProtection _protector

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    int slno = 1;
    bool editable = (bool)ViewBag.Editable;
}
<div class="container">

    <div class="alert alert-danger" role="alert" style="margin-top:5px;">
         Application Id : @Model.Id |   Application is at : <b>@Model.Owner</b> | Application Type : <b id="LoanScheme">@Model.LoanScheme</b> | Applied Amount : <b id="appAmt">@Model.LoanApplications.Sum(a=> a.AppliedAmount)</b> <br/>
        Application status is : <b>@Model.Status</b> , Application Bucket : @Model.OwnerUser <br/> @if (Model.Status == "Sanctioned")
        {
            <b>Sanctioned By : @Model.SanctioningUserId (@Model.SanctioningLevel)</b>
           
            <span>Control Status : @Model.ControlStatus</span>
           
        }
        
    </div>

   

    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <tr>
            <td colspan="4">
                <b>Basic Application Details</b>
            </td>
            <td colspan="2">
                @if (editable)
        {
            if(Model.Owner == "RO" || Model.Owner == "AMH" || Model.Owner == "HO")
            {
                <a class="btn-danger btn btn-sm" href="/LoanFlow/ThirdParty/@Model.Id" data-toggle="modal" data-target="#applicantModal">External Verification</a>
            }
        }
                 @*<a class="btn btn-primary btn-sm" href="/LoanFlow/SendApplication?Id=@Model.Id" data-toggle="modal" data-target="#searchModal">Send Application</a>*@
            </td>
        </tr>
        <tr>
            
            <td><b>Branch</b></td>
            <td>@Model.BranchId</td>
            <td><b>Name</b></td>
            <td>@Model.ApplicantShortName</td>
            <td><b>Applicant Type</b></td>
            <td>@Model.TypeOfApplicant</td>
           
        </tr>
        <tr>
            
            <td><b>Scheme</b></td>
            <td>@Model.LoanScheme</td>
            <td><b>Purpose</b></td>
            <td>@Model.Purpose</td>
            <td><b>Status</b></td>
            <td>@Model.Status</td>
            
        </tr>
        <tr>
            
            <td><b>Sponsoring Agency</b></td>
            <td>@Model.SponsoringAgency</td>
            <td><b>Subsidy</b></td>
            <td>@Model.SubsidyAmt</td>
            <td><b>Application Date</b></td>
            <td>@Model.ApplicationDate.ToShortDateString()</td>
            
        </tr>
        <tr>
            <td><b>External Verification Alloted To:</b></td>
            <td>@Model.InspectionAllotedTo</td>
            <td><b>External Inspection Done:</b></td>
            <td>@Model.InspectionDone</td>
            <td></td>
            <td></td>
        </tr>
    </table>

   

    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td colspan="5">Details of Applicant</td>
                <td colspan="2"> @if (editable)
                    {
                        <a href="/LoanFlow/AddApplicant/@Model.Id" class="btn btn-primary btn-sm" >
                        Add Applicant
</a> <a href="/LoanFlow/SearchApplicant/@Model.Id" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#searchModal">
 Copy / Search
</a>    
                    }
                    </td>
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Name
                </th>
                <th>
                    Type
                </th>
                <th>
                    Date of Birth
                </th>
                <th>
                    Occupation
                </th>
                <th>
                    KYC Document
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody id="applicantTable">
            @foreach(var x in Model.Applicants.Where(a=> a.Driving_Lic != "Deleted"))
            {

                <tr>
                    <td>@slno</td>
                    <td>@x.Salutation @x.Applicant_First_Name @x.Applicant_Middle_Name @x.Applicant_Last_Name @x.Relationship @x.Guardian_Name</td>
                    <td>@x.TypeofApplicant</td>
                    <td>@x.Date_Of_Birth</td>
                    <td>@x.Occupation</td>
                    <td>
                        @if (x.KYC_Upload !=  null)
                        {
                            <a href="/@x.KYC_Upload" target="_blank">Download KYC</a>  
                        }
                        
                    </td>
                    <td>
                        @if (editable)
                        {
                            <a class="btn-danger btn btn-sm" href="/LoanFlow/EditApplicant/@x.Id" data-toggle="modal" data-target="#applicantModal">Edit</a>  <button type="button" class="btn btn-sm btn-warning" onclick="deleteApp(@x.Id)" >Delete</button>  <button type="button" class="btn btn-sm btn-warning" data-toggle="modal" data-target="#loadingModal" onclick="cibilApp(@x.Id);" >Get CIBIL</button>    
                        }
                        
                    </td>
                </tr>
                slno++;
            }
        </tbody>

    </table>

    @if (Model.Status == "Sanctioned")
    {
        <table  class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="7">eMandates   <a class="btn btn-sm btn-danger" href="/LoanFlow/AddMandate/@Model.Id"> Add eMandate</a></th>
            </tr>
            <tr>
                <td>Bank Name</td>
                <td>Account No</td>
                <td>EMI</td>
                <td>First Collection Date</td>
                <td>Status</td>
                <td>Last Run Date</td>
                <td>LAst Run Status</td>
            </tr>
            </thead>  
            <tbody>
               @foreach(var x in Model.Mandates)
                {
                    <tr>
                        <td>@x.instructed_agent_code</td>
                        <td>@x.debtor_account_id</td>
                        <td>@x.amount</td>
                        <td>@x.first_collection_date</td>
                        <td>@x.mandate_status</td>
                        <td>@x.last_run_date</td>
                        <td>@x.last_run_status</td>
                    </tr>   
                }
            </tbody>

        </table>
        
    }


    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="8">Cibil Details (Latest enquiry will be used for calculation)</th>
            </tr>
            <tr>
                <th>S.No.</th>
                <th>Applicant Name</th>
                <th>Cibil Score</th>
                <th>Date</th>
                <th>Total Accounts</th>
                <th>Closed Accounts</th>
                <th>Overdue Accounts</th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody id="cibilTable">
            @{
                int crCount = 1;
            }
            @foreach(var x in (List<CIBILRequest>)ViewBag.CreditScore)
            {
                <tr>
                    <td>@crCount</td>
                    <td>@x.ApplicantDetail.Applicant_First_Name @x.ApplicantDetail.Applicant_Last_Name</td>
                    <td><a href="/Home/CreditScore/@x.Id">@x.ScoreName1 </a>  </td>
                    <td>@x.RequestDate</td>
                    <td>@x.CibilLoans.Count()</td>
                    <td>@x.CibilLoans.Where(a => a.currentBalance == "0").Count()</td>
                    <td>@x.CibilLoans.Where(a => int.Parse(a.amountOverdue ?? "0") != 0).Count()</td>
                    <td> @if (editable)
                        { <a class="btn btn-sm btn-primary" href="/Home/UpdateEmi/@x.Id">Update EMI</a> <a class="btn btn-sm btn-info" href="/LoanFlow/AddCibil/@x.Id" data-toggle="modal" data-target="#applicantModal">Add Additional Loan</a>}
                         </td>
                </tr>
                crCount++;
            }
        </tbody>
    </table>


    
     <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="8">Account Statement Through Aggregator (Other Than our Bank)</th>
            </tr>
            <tr>
                <th>S.No.</th>
                <th>Mobile Number</th>
                <th>Status</th>
                <th>Bank Name</th>
                <th>Account Detail</th>
                
                <th>
                     @if (editable)
                    {
                        <a href="/LoanFlow/AddStatement/@Model.Id" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#applicantModal">
                        Request
</a>    
                    }
                </th>
                
            </tr>
        </thead>
        <tbody>
            @{
                int s = 1;   
            }
            @foreach(var x in Model.AccountStatments)
            {
                    <tr>
                        <td>@s</td>
                        <td>@x.MobileNumber</td>
                        <td>@x.request_status</td>
                        <td></td>
                        <td></td>
                        <td><a href="/LoanFlow/AACheck?id=@x.Id">View</a></td>

                    </tr>
                s++;
            }

        </tbody>
        </table>


     <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="8">Project Cost</th>
            </tr>
            <tr>
                <th>S.No.</th>
                <th>Description</th>
                <th>Eligible for Bank Finance</th>
                <th>Cost</th>
                <th>Bank Finance</th>
                
                <th>
                     @if (editable)
                    {
                        <a href="/LoanFlow/AddProjectCost/@Model.Id" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#applicantModal">
                        Add Project Cost
</a>    
                    }
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody id="pjTable">
            @{
                int pjCount = 1;
            }
            @foreach(var x in (List<ProjectCost>)ViewBag.ProjectCost)
            {
                <tr>
                    <td>@pjCount</td>
                    <td>@x.Description</td>
                    <td>@x.EligibleForLoan  </td>
                    <td>@x.Cost</td>
                    <td>@x.AppliedAmount</td>
                   
                    <td>@if (editable)
                        {
                            <button type="button" class="btn btn-sm btn-warning" onclick="deletePj(@x.Id)" >Delete</button>    
                        }</td>
                </tr>
                pjCount++;
            }
        </tbody>
    </table>


    @if (Model.LoanScheme == "MUDRA-Transport")
    {
        <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="2">Vehichle / Equipment  Details</th>
                <th >
                     @if (editable)
                    {
                              
                        <a href="/LoanFlow/TPL/@Model.Id" class="btn btn-primary btn-sm">
                        Add Details
</a>    
 <a href="/LoanFlow/MudraDetails/@Model.Id" class="btn btn-primary btn-sm">
                        Add Details (M)
</a>    
                    }
                </th>
                <th>
                     <a href="/LoanFlow/Eligibility/@Model.Id" data-toggle="modal" data-target="#applicantModal" class="btn btn-danger btn-sm">
                        DSCR</a>
                </th>
            </tr>
            <tr>
                <th>Manufacturer</th>
                <th>Model</th>
                <th>Type of Vehichle</th>
                
                
                
                <th>Mileage</th>
            </tr>
        </thead>
        <tbody id="tplTable">
                @if (Model.TPLDetails != null)
                { 
                
                <tr>
                 <td>@Model.TPLDetails.Manufacturer</td>
                 <td>@Model.TPLDetails.Model</td>
                 <td>@Model.TPLDetails.TypeOfVehichle</td>
                 <td>@Model.TPLDetails.Mileage @Model.TPLDetails.ReferenceUnit / 
                       @if (Model.TPLDetails.TypeOfVehichle == "Electric")
                {
                     <span>Charge</span>
                }
                else
                {
                     <span>Ltr</span>
                }

                 </td>
             </tr>}

             
        </tbody>
    </table>
    }

    @if (Model.LoanScheme.Contains("KCC") )
    {
          <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="2">Agri Land Details</th>
                <th colspan="4">
                     @if (editable)
                    {
                              
                        <a href="/LoanFlow/UpdateKCCLand/@Model.Id" class="btn btn-primary btn-sm">
                        Update KCC Land (Mobile)
</a>    <a href="/LoanFlow/SplitLand/@Model.Id" data-toggle="modal" data-target="#applicantModal"  class="btn btn-sm btn-warning" >Split</a> 
                    }
                </th>
            </tr>
            <tr>
                <th>S.No.</th>
                <th>Description</th>
                <th>Irrigated Area</th>
                <th>Unirrigated Area</th>
                <th>Total Area </th>
                
                
                <th></th>
            </tr>
        </thead>
        <tbody id="kccTable">
            @{
                int kccCount = 1;
            }
            @foreach(var x in Model.KCCLandDetails)
            {
                <tr>
                    <td>@kccCount</td>
                    <td>@x.OwnerName | District - @x.District | Village - @x.Village | Khasra No - @x.KhasraNo</td>
                    <td>@x.IrrigatedArea  Hect. </td>
                    <td>@x.UnIrrigatedArea Hect.</td>
                    <td>@x.TotalArea Hect. </td>
                   
                    <td>@if (editable)
                        {
                            <button type="button" class="btn btn-sm btn-warning" onclick="deleteKCC(@x.Id)" >Delete</button>    
                               
                        }</td>
                </tr>
                kccCount++;
            }
        </tbody>
    </table>
    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <th colspan="1">Crop Details</th>
                <th colspan="6">
                     @if (editable)
                    {
                        <a href="/LoanFlow/AddCrop?Id=@Model.Id&season=Kharif" class="btn btn-primary btn-sm">
                        Add Kharif Crop</a>    
                        <a href="/LoanFlow/AddCrop?Id=@Model.Id&season=Rabi" class="btn btn-primary btn-sm">
                        Add Rabi Crop</a>
                        <a href="/LoanFlow/AddCrop?Id=@Model.Id&season=Summer" class="btn btn-primary btn-sm">
                        Add Summer Crop</a>
                        <a href="/LoanFlow/Eligibility/@Model.Id" data-toggle="modal" data-target="#applicantModal" class="btn btn-danger btn-sm">
                        View Limit</a>
                    }
                </th>
            </tr>
            <tr>
                <th>S.No.</th>
                <th>Description</th>
                <th>Irrigated Area</th>
                <th>Unirrigated Area</th>
                <th>Season </th>
                <th>Crop </th>
                
                <th></th>
            </tr>
        </thead>
        <tbody id="kccTable">
            @{
                int cropCount = 1;
            }
            @foreach(var x in (List<KCCCropDetail>)ViewBag.KCCCropDetails)
            {
                <tr>
                    <td>@cropCount</td>
                    <td>District - @x.KCCLandDetails.District | Village - @x.KCCLandDetails.Village | Khasra No - @x.KCCLandDetails.KhasraNo</td>
                    <td>@x.IrrigatedArea  Hect. </td>
                    <td>@x.UnIrrigatedArea Hect.</td>
                    <td>@x.Season </td>
                   <td>@x.Crop </td>
                    <td>@if (editable)
                        {
                            <button type="button" class="btn btn-sm btn-warning" onclick="deleteKCCCrop(@x.Id)" >Delete</button>    
                        }</td>
                </tr>
                cropCount++;
            }
        </tbody>
    </table>
    }

   

     @if (Model.Status == "Sanctioned")
    {
          <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td colspan="10"><b>Sanction Details</b></td>
               
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Type of Facility
                </th>
                <th>
                    Purpose
                </th>
                <th>
                    Cost
                </th>
                <th>
                    Applied Amount
                </th>
                <th>Sanctioned Amount</th>
                <th>ROI</th>
                <th>Repay Start Date</th>
                <th>Repay Amount</th>
                <th>Repay Term</th>
            </tr>
        </thead>
        <tbody>
            @{
                slno = 1;
            }
            @foreach(var x in Model.LoanApplications)
            {

                <tr>
                    <td>@slno</td>
                    <td>@x.TypeOfFacility </td>
                    <td>@x.Description</td>
                    <td>@x.Cost</td>
                    <td>@x.AppliedAmount</td>
                     <td>@x.SanctionedAmount</td>
                    <td>@x.RateOfInterest</td>
                    <td>@x.RepayStartDate</td>
                    <td>@x.Repayment</td>
                    <td>@x.RepayTerm</td>
                </tr>
                slno++;
            }
        </tbody>

        </table>
    
        <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td ><b>Charges</b></td>
               
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Description
                </th>
                <th>
                    Amount
                </th>
                <th>
                    Percentage (For Document)
                </th>
               
                
            </tr>
        </thead>
        <tbody>
            @{
                slno = 1;
            }
            @foreach(var x in Model.Charges)
            {

                <tr>
                    <td>@slno</td>
                    <td>@x.Details </td>
                    <td>@x.TotalAmount</td>
                    <td>@x.Percentage</td>
                   
                    
                     
                </tr>
                slno++;
            }
        </tbody>

    </table>
     <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td ><b>Disbursement Schedule</b></td>
             
            </tr>
            <tr>
                <th>
                    S.No.
                </th>
                <th>
                    Description
                </th>
                <th>
                    Total Investment
                </th>
                <th>
                    Bank Contribution
                </th>
               
                
            </tr>
        </thead>
        <tbody>
            @{
                slno = 1;
            }
            @foreach(var x in Model.Disbursements)
            {

                <tr>
                    <td>@slno</td>
                    <td>@x.Details </td>
                    <td>@x.TotalAmount</td>
                    <td>@x.BankPart</td>
                    
                  
                    
                     
                </tr>
                slno++;
            }
        </tbody>

    </table>
    }
    else
