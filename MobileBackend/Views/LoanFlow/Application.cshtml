    <table class="table table-bordered table-sm" style="padding-top:5px;">
        <thead>
            <tr>
                <td colspan="3"><b>Attached Documents</b></td>
                <td colspan="2">
                 
                    
                        <a href="/LoanFlow/AddDocument/@Model.Id"  class="btn btn-primary btn-sm" data-toggle="modal" data-target="#applicantModal">
 Add 
</a> 
                    

                    

</td>
            </tr>
