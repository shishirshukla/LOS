@model LeadCollection
@{
    ViewData["Title"] = "Lead List";
}


<div class="container">
 
   <div class="row">
       
         <section id="tabs" class="project-tab col-12" style="padding-top:5px;margin-top: 0px; padding-bottom:60px;">
           
                <div class="row">
                    <div class="col-md-12">
                        <nav>
                            <div class="nav nav-tabs nav-fill" id="nav-tab" role="tablist">
                                <a class="nav-item nav-link active" id="nav-home-tab" data-toggle="tab" href="#nav-home" role="tab" aria-controls="nav-home" aria-selected="true">KCC Leads</a>
                                <a class="nav-item nav-link" id="nav-profile-tab" data-toggle="tab" href="#nav-profile" role="tab" aria-controls="nav-profile" aria-selected="false">TPL Leads</a>
                                <a class="nav-item nav-link" id="nav-contact-tab" data-toggle="tab" href="#nav-contact" role="tab" aria-controls="nav-contact" aria-selected="false">Gold Leads</a>
                                 <a class="nav-item nav-link" id="nav-gen-tab" data-toggle="tab" href="#nav-gen" role="tab" aria-controls="nav-gen" aria-selected="false">General Leads</a>
                            </div>
                        </nav>
                        <div class="tab-content" id="nav-tabContent">
                            <div class="tab-pane fade show active" id="nav-home" role="tabpanel" aria-labelledby="nav-home-tab">
                               <b class="display-8">KCC Leads</b>
        <table class="table table-sm table-striped table-bordered" id="kccl">
            <thead>
                <tr>
                    <th>Branch</th>
                    <th>Sourcing Unit</th>
                    <th>Sourced By</th>
                    <th>Applicant Name</th>
                     <th>Lead Amount</th>
                     <th>Lead Status</th>
                     <th>Lead Date</th>
                     <th></th>
                </tr>
            </thead>
            
            @foreach(var item in Model.KCCLead)
            {
                <tr>
                    <td>@item.Branch.BranchName</td>
                    <td>@item.SourcingAgency</td>
                    <td>@item.SourcedBy</td>
                    <td>@item.ApplicantName</td>
                     <td>@item.AppliedAmt</td>
                      <td>@item.LeadStatus</td>
                      <td>@item.LeadDate</td>
                      <td><a href= "/Mobile/ViewLead?Id=@item.Id&LeadType=KCC">View</a></td>
                </tr>
                    
                }
         </table>
    
                            </div>
                            <div class="tab-pane fade" id="nav-profile" role="tabpanel" aria-labelledby="nav-profile-tab">
                                <b class="display-8">TPL Leads</b>
        <table class="table table-sm table-striped table-bordered" id="tpll">
            <thead>
                <tr>
                    <th>Branch</th>
                    <th>Sourcing Unit</th>
                    <th>Sourced By</th>
                    <th>Applicant Name</th>
                     <th>Lead Amount</th>
                     <th>Lead Status</th>
                     <th>Lead Date</th>
                     <th></th>
                </tr>
            </thead>
            
            @foreach(var item in Model.TPLLeads)
            {
                <tr>
                    <td>@item.Branch.BranchName</td>
                    <td>@item.SourcingAgency</td>
                    <td>@item.SourcedBy</td>
                    <td>@item.ApplicantName</td>
                     <td>@item.AppliedAmt</td>
                      <td>@item.LeadStatus</td>
                      <td>@item.LeadDate</td>
                      <td><a href= "/Mobile/ViewLead?Id=@item.Id&LeadType=TPL">View</a></td>
                </tr>
                    
                }
         </table>
                            </div>
                                 <div class="tab-pane fade" id="nav-contact" role="tabpanel" aria-labelledby="nav-contact-tab">
                                <b class="display-8">Gold Leads</b>
        <table class="table table-sm table-striped table-bordered" id="goldl">
            <thead>
                <tr>
                    <th>Branch</th>
                    <th>Sourcing Unit</th>
                    <th>Sourced By</th>
                    <th>Applicant Name</th>
                     <th>Lead Amount</th>
                     <th>Lead Status</th>
                     <th>Lead Date</th>
                     <th></th>
                </tr>
            </thead>
            
            @foreach(var item in Model.GoldLoanLeads)
            {
                <tr>
                    <td>@item.Branch.BranchName</td>
                    <td>@item.SourcingAgency</td>
                    <td>@item.SourcedBy</td>
                    <td>@item.ApplicantName</td>
                     <td>@item.AppliedAmt</td>
                      <td>@item.LeadStatus</td>
                      <td>@item.LeadDate</td>
                      <td><a href= "/Mobile/ViewLead?Id=@item.Id&LeadType=Gold">View</a></td>
                </tr>
                    
                }
         </table>
                            </div>

                             <div class="tab-pane fade" id="nav-gen" role="tabpanel" aria-labelledby="nav-gen-tab">
                                <b class="display-8">Other Leads</b>
        <table class="table table-sm table-striped table-bordered" id="genl">
            <thead>
                <tr>
                    <th>Branch</th>
                    <th>Sourcing Unit</th>
                    <th>Sourced By</th>
                    <th>Applicant Name</th>
                     <th>Lead Amount</th>
                     <th>Lead Status</th>
                     <th>Lead Date</th>
                     <th></th>
                </tr>
            </thead>
            
            @foreach(var item in Model.GeneralLeads)
            {
                <tr>
                    <td>@item.Branch.BranchName</td>
                    <td>@item.SourcingAgency</td>
                    <td>@item.SourcedBy</td>
                    <td>@item.ApplicantName</td>
                     <td>@item.AppliedAmt</td>
                      <td>@item.LeadStatus</td>
                      <td>@item.LeadDate</td>
                      <td><a href= "/Mobile/ViewLead?Id=@item.Id&LeadType=Gen">View</a></td>
                </tr>
                    
                }
         </table>
                            </div>
                          
                        </div>
                    </div>
                </div>
          
        </section>
   </div>
    


</div>
   
@section scripts
{
    <link rel="stylesheet" type="text/css" href="/js/datatables.min.css"/>
    <script type="text/javascript" src="/js/datatables.min.js"></script>
    <script src="~/js/datatable-button.js" asp-append-version="true"></script>
    <script src="~/js/html5btn.js" asp-append-version="true"></script>
    <script type="text/javascript">
            $(document).ready( function () {
                    $('#genl').DataTable({dom: 'Bfrtip',buttons: ['csv', 'pdf']});
                    $('#kccl').DataTable({dom: 'Bfrtip',buttons: ['csv', 'pdf']});
                    $('#tpll').DataTable({dom: 'Bfrtip',buttons: ['csv', 'pdf']});
                    $('#goldl').DataTable({dom: 'Bfrtip',buttons: ['csv', 'pdf']});
        } );
    </script>
     
}

   
   
  
 
   
   








