@{
    Layout = null;
}
<form method="post" action="/Mobile/TakeAction" enctype="multipart/form-data" >
    <input type="hidden" value="@ViewBag.LeadId" name="LeadId"/>
     
   <input type="hidden" value="@ViewBag.LeadType" name="LeadType"/>
   <div class="row justify-content-between text-left">
 
  <div class="form-group col-sm-6 flex-column d-flex">
    <label >Select Action</label>
  <select id="actionList" class="form-control-sm" name="UpdateAction">
            <option value="-----">Select</option>
        @foreach (var item in (List<string>)ViewBag.AvailableActions)
        {
            <option value="@item">@item</option>
        }
      
    </select>
  </div>
  <div class="form-group col-sm-6 flex-column d-flex">
  <label >Remarks</label>
     <textarea name="Statment" class="form-control" required>

     </textarea>

  </div>
 
  </div>
   
 
  
 
  
 
   
  
    <button type="submit" class="btn btn-primary">Submit</button>
 
  
  
</form>