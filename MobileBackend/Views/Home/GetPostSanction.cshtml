@model List<PostSanctionVisit>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    int sl = 1;
}

<table class="table table-sm">
    <thead>
        <tr>
            <th>S.No</th>
            <th>Inspection Date</th>
            <th>User Id</th>
            <th></th>
        </tr>

    </thead>
    <tbody>
        @foreach (var item in Model)
       {
            <tr>
                <td>@sl</td>
                <td>@item.VisitDate.ToString()</td>
                <td>@item.UserId</td>
                <td><a href="/Home/ViewPostReport/@item.Id">View</a></td>
            </tr>
            sl++;
        }
        
    </tbody>

</table>