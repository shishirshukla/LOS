@{
	Layout = "../Shared/_BaseImport.cshtml";
	var certificate = (MobileBackend.Models.PAN.Certificate)ViewBag.Certificate;
}
<div class="container h-100">
		<div class="d-flex justify-content-center h-100">
			 <div class="ok_card card" style="width: 18rem;">
  <div class="card-body">
  
        @if (ViewBag.Error == "OK")
			{
				

					<p>
						<b>PAN No issued to : </b> @certificate.IssuedTo.Person.Name
					</p>
					<p>
						<b>DOB As PAN : </b> @certificate.IssuedTo.Person.Dob
					</p>
<p>
						<b>Gender As PAN : </b> @certificate.IssuedTo.Person.Gender
					</p>
					<p>
						<b>Verified on : </b> @certificate.CertificateData.PAN.VerifiedOn
					</p>
					<p>
						<b>PAN Number </b> @certificate.Number
					</p>
					<p>
						<b>Ref Id : </b> @certificate.IssuedTo.Person.Email
					</p>
				 
				
			}
			else if (ViewBag.Error != "")
			{
				

					<p>
						 @ViewBag.Error
					</p>

				
			}
  </div>
</div>
		




