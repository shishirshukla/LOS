@model PANResponse
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = null;
}

@if (Model != null)
{
    <table class="table table-sm">
        <tr>
            <td>PAN Number</td>
            <td>@Model.data.pan</td>
        </tr>
        <tr>
            <td>First Name</td>
            <td>@Model.data.first_name</td>
        </tr>
        <tr>
            <td>Middle Name</td>
            <td>@Model.data.middle_name</td>
        </tr>
        <tr>
            <td>Last Name</td>
            <td>@Model.data.last_name</td>
        </tr>
        <tr>
            <td>Status</td>
            <td>@Model.data.status</td>
        </tr>
        <tr>
            <td>Adhaar Seeding Status</td>
            <td>@Model.data.aadhaar_seeding_status</td>
        </tr>
        <tr>
            <td>Category</td>
            <td>@Model.data.category</td>
        </tr>
    </table>
    
}
else
{
    <b>Verification could not be done</b>
}

